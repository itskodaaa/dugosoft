{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "subscription": {
      "type": "string",
      "description": "User subscription tier",
      "enum": [
        "free",
        "pro",
        "business"
      ],
      "default": "free"
    }
  },
  "required": [
    "role"
  ]
}